# ============================================================
# CircuitAI Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ----- Application -----
APP_ENV=development               # development | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ----- Database -----
DATABASE_URL=postgresql+asyncpg://circuitai:circuitai@localhost:5432/circuitai_db

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ----- OpenAI -----
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=3

# ----- Xyce Simulation -----
XYCE_DOCKER_IMAGE=xyce:latest
XYCE_WORKSPACE_BASE=/tmp/xyce_jobs
XYCE_TIMEOUT_SECONDS=300
XYCE_MEMORY_LIMIT=2g
XYCE_CPU_QUOTA=100000
USE_MOCK_XYCE=true              # set false when real Xyce Docker image available

# ----- Artifact Storage -----
ARTIFACT_STORAGE_PATH=/tmp/circuitai_artifacts
# ARTIFACT_S3_BUCKET=my-bucket     # uncomment when using S3

# ----- Optimization -----
MAX_OPTIMIZATION_ITERATIONS=5
MC_SAMPLE_COUNT=200

# ----- API Auth (optional) -----
API_KEY_ENABLED=false
API_KEY=change-me-api-key
